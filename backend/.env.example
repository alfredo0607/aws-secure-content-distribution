# ── SERVER ──────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# Connection Pool
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000
DB_CONNECT_TIMEOUT=10000

# ── SECURITY ─────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_very_long_random_secret_min_64_chars
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=another_very_long_random_secret_for_refresh_tokens
JWT_REFRESH_EXPIRES_IN=7d

# ── RATE LIMITING ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ── LOGS ─────────────────────────────────────────────────────
LOG_LEVEL=dev

# ── AWS ──────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_PUBLIC_KEY=<your-access-key-id>
AWS_PRIVATE_KEY=<your-secret-access-key>
AWS_BUCKET_NAME=<your-bucket-name>

# ── CLOUDFRONT ───────────────────────────────────────────────
CLOUDFRONT_KEYPAIR_ID=<your-key-pair-id>
CLOUDFRONT_PRIVATE_KEY=/absolute/path/to/privkey.pem
CLOUDFRONT_DOMAIN=https://xxxxxxxxxxxx.cloudfront.net
