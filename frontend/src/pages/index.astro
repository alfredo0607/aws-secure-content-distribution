---
import Layout from '../layouts/Layout.astro';

const API_URL = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000/api/v1';
---

<Layout>
  <div class="min-h-screen bg-gray-950 flex flex-col">

    <!-- ── Header ─────────────────────────────────────────────────────────── -->
    <header class="sticky top-0 z-10 border-b border-gray-800 bg-gray-950/80 backdrop-blur-sm">
      <div class="mx-auto max-w-5xl px-6 py-4 flex items-center gap-3">
        <!-- Cloud icon -->
        <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-blue-600/10 ring-1 ring-blue-500/20">
          <svg class="h-5 w-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
              d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" />
          </svg>
        </div>
        <div>
          <h1 class="text-base font-semibold text-white leading-tight">AWS Secure Content Distribution</h1>
          <p class="text-xs text-gray-500">S3 · CloudFront · OAC · Signed URLs</p>
        </div>
        <div class="ml-auto flex items-center gap-2">
          <span class="rounded-full bg-blue-500/10 px-3 py-1 text-xs font-medium text-blue-400 ring-1 ring-blue-500/20">
            Demo
          </span>
          <a
            href="https://github.com/alfredo0607/aws-secure-content-distribution"
            target="_blank"
            rel="noopener noreferrer"
            title="Ver repositorio en GitHub"
            class="inline-flex items-center gap-1.5 rounded-lg border border-gray-700 bg-gray-800/60 px-3 py-1.5 text-xs font-medium text-gray-300 hover:bg-gray-700 hover:text-white transition-colors"
          >
            <!-- GitHub icon -->
            <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
            </svg>
            Repositorio
          </a>
        </div>
      </div>
    </header>

    <main class="flex-1 mx-auto w-full max-w-5xl px-6 py-8 space-y-6">

      <!-- ── Toast ──────────────────────────────────────────────────────────── -->
      <div id="toast" class="hidden items-center gap-2.5 rounded-lg border px-4 py-3 text-sm font-medium"></div>

      <!-- ── Intro banner ──────────────────────────────────────────────────── -->
      <section class="rounded-xl border border-gray-800 bg-linear-to-br from-gray-900 to-gray-900/60 p-6">
        <div class="flex flex-col sm:flex-row sm:items-start gap-4">

          <!-- Icon -->
          <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-blue-600/15 ring-1 ring-blue-500/25">
            <svg class="h-6 w-6 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
            </svg>
          </div>

          <!-- Text -->
          <div class="flex-1 min-w-0">
            <h2 class="text-base font-semibold text-white">¿Qué es este proyecto?</h2>
            <p class="mt-1.5 text-sm text-gray-400 leading-relaxed">
              Demo de una arquitectura de distribución de contenido <span class="text-gray-200 font-medium">completamente privada</span> sobre AWS.
              Los archivos se almacenan en un bucket <span class="text-gray-200 font-medium">S3 sin acceso público</span> y solo
              son accesibles a través de <span class="text-gray-200 font-medium">URLs firmadas de CloudFront</span> que expiran
              en un tiempo determinado — ningún archivo puede ser descargado sin un enlace autorizado y vigente.
            </p>

            <!-- Flow chips -->
            <div class="mt-4 flex flex-wrap items-center gap-2 text-xs">
              <span class="inline-flex items-center gap-1.5 rounded-full bg-gray-800 px-3 py-1.5 text-gray-300 ring-1 ring-gray-700">
                <svg class="h-3.5 w-3.5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5" />
                </svg>
                1. Subes un archivo
              </span>
              <svg class="h-3.5 w-3.5 text-gray-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
              <span class="inline-flex items-center gap-1.5 rounded-full bg-gray-800 px-3 py-1.5 text-gray-300 ring-1 ring-gray-700">
                <svg class="h-3.5 w-3.5 text-violet-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" />
                </svg>
                2. Se guarda en S3 privado
              </span>
              <svg class="h-3.5 w-3.5 text-gray-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
              <span class="inline-flex items-center gap-1.5 rounded-full bg-gray-800 px-3 py-1.5 text-gray-300 ring-1 ring-gray-700">
                <svg class="h-3.5 w-3.5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
                </svg>
                3. Generas un enlace con expiración
              </span>
            </div>
          </div>

        </div>

        <!-- Tech badges -->
        <div class="mt-5 flex flex-wrap gap-2 border-t border-gray-800 pt-4">
          {[
            { label: 'Amazon S3',    color: 'text-orange-400 bg-orange-400/8 ring-orange-400/20' },
            { label: 'CloudFront',   color: 'text-purple-400 bg-purple-400/8 ring-purple-400/20' },
            { label: 'OAC + SigV4', color: 'text-blue-400   bg-blue-400/8   ring-blue-400/20'   },
            { label: 'Signed URLs',  color: 'text-green-400  bg-green-400/8  ring-green-400/20'  },
            { label: 'SSE-KMS',      color: 'text-yellow-400 bg-yellow-400/8 ring-yellow-400/20' },
          ].map(({ label, color }) => (
            <span class={`rounded-full px-2.5 py-1 text-xs font-medium ring-1 ${color}`}>{label}</span>
          ))}
        </div>
      </section>

      <!-- ── Upload card ────────────────────────────────────────────────────── -->
      <section class="rounded-xl border border-gray-800 bg-gray-900 p-6">
        <h2 class="mb-4 text-xs font-semibold uppercase tracking-widest text-gray-500">Upload file</h2>

        <!-- Drop zone -->
        <div
          id="drop-zone"
          class="relative flex flex-col items-center justify-center gap-2 rounded-lg border-2 border-dashed border-gray-700 bg-gray-950/40 py-14 px-6 text-center transition-all duration-150 cursor-pointer hover:border-blue-500/60 hover:bg-blue-500/5"
        >
          <svg class="h-10 w-10 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
              d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5" />
          </svg>
          <p class="text-sm text-gray-400">
            <span class="font-medium text-blue-400">Haz clic para seleccionar</span> o arrastra y suelta
          </p>
          <p class="text-xs text-gray-600">PNG, JPG, GIF, PDF, SVG — máx. 10 MB</p>
          <input type="file" id="file-input" class="absolute inset-0 opacity-0 cursor-pointer" />
        </div>

        <!-- File preview -->
        <div id="file-preview" class="hidden mt-3 flex items-center gap-3 rounded-lg border border-gray-700 bg-gray-800/50 px-4 py-3">
          <svg class="h-5 w-5 shrink-0 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
              d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
          </svg>
          <span id="file-name" class="flex-1 min-w-0 truncate text-sm text-gray-200"></span>
          <span id="file-size" class="shrink-0 text-xs text-gray-500"></span>
          <button id="clear-btn" class="shrink-0 rounded p-0.5 text-gray-600 hover:text-gray-300 transition-colors">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>

        <!-- Upload button -->
        <button
          id="upload-btn"
          disabled
          class="mt-4 w-full rounded-lg bg-blue-600 px-4 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-blue-500 disabled:opacity-40 disabled:cursor-not-allowed flex items-center justify-center gap-2"
        >
          <svg id="upload-icon" class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5" />
          </svg>
          <svg id="upload-spinner" class="hidden h-4 w-4 animate-spin" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"></path>
          </svg>
          <span id="upload-label">Subir a S3</span>
        </button>
      </section>

      <!-- ── Files card ─────────────────────────────────────────────────────── -->
      <section class="rounded-xl border border-gray-800 bg-gray-900 p-6">
        <div class="mb-5 flex items-center justify-between">
          <h2 class="text-xs font-semibold uppercase tracking-widest text-gray-500">Archivos en S3</h2>
          <button
            id="refresh-btn"
            class="flex items-center gap-1.5 rounded-lg px-3 py-1.5 text-xs text-gray-400 hover:bg-gray-800 hover:text-gray-200 transition-colors"
          >
            <svg id="refresh-icon" class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
            </svg>
            Actualizar
          </button>
        </div>

        <!-- Loading state -->
        <div id="state-loading" class="flex justify-center py-14">
          <svg class="h-5 w-5 animate-spin text-blue-500" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"></path>
          </svg>
        </div>

        <!-- Empty state -->
        <div id="state-empty" class="hidden flex flex-col items-center gap-2 py-14 text-center">
          <svg class="h-10 w-10 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
              d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4" />
          </svg>
          <p class="text-sm text-gray-500">No hay archivos subidos</p>
          <p class="text-xs text-gray-700">Sube el primero usando el formulario de arriba</p>
        </div>

        <!-- Table -->
        <div id="state-table" class="hidden overflow-x-auto -mx-2">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-gray-800">
                <th class="px-2 pb-3 text-left text-xs font-medium text-gray-500">Nombre</th>
                <th class="px-2 pb-3 text-left text-xs font-medium text-gray-500">Tamaño</th>
                <th class="px-2 pb-3 text-left text-xs font-medium text-gray-500">Modificado</th>
                <th class="px-2 pb-3 text-right text-xs font-medium text-gray-500">Acciones</th>
              </tr>
            </thead>
            <tbody id="files-tbody" class="divide-y divide-gray-800/60"></tbody>
          </table>
        </div>
      </section>

    </main>

    <!-- ── Footer ─────────────────────────────────────────────────────────── -->
    <footer class="border-t border-gray-800 bg-gray-900/30">
      <div class="mx-auto max-w-5xl px-6 py-5 flex flex-col sm:flex-row items-center justify-between gap-4">
        <!-- Developer info -->
        <div class="flex items-center gap-2 text-sm">
          <svg class="h-4 w-4 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
              d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <span class="text-gray-500">Desarrollado por</span>
          <span class="font-medium text-gray-300">Alfredo Jose Dominguez Hernandez</span>
        </div>

        <!-- Social buttons -->
        <div class="flex items-center gap-2">
          <!-- LinkedIn -->
          <a
            href="https://www.linkedin.com/in/alfredo-jose-dominguez-hernandez"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 rounded-lg border border-gray-700 bg-gray-800/60 px-3 py-1.5 text-xs font-medium text-gray-300 hover:border-blue-600/50 hover:bg-blue-600/10 hover:text-blue-400 transition-colors"
          >
            <!-- LinkedIn icon -->
            <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
            </svg>
            LinkedIn
          </a>

          <!-- GitHub -->
          <a
            href="https://github.com/alfredo0607/aws-secure-content-distribution"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 rounded-lg border border-gray-700 bg-gray-800/60 px-3 py-1.5 text-xs font-medium text-gray-300 hover:border-gray-500 hover:bg-gray-700 hover:text-white transition-colors"
          >
            <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
            </svg>
            Repositorio
          </a>
        </div>
      </div>
    </footer>

  </div>

  <!-- ── Signed URL Modal ──────────────────────────────────────────────────── -->
  <div id="modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/70 backdrop-blur-sm">
    <div class="w-full max-w-lg rounded-xl border border-gray-700 bg-gray-900 p-6 shadow-2xl shadow-black/50">

      <!-- Modal header -->
      <div class="mb-5 flex items-start justify-between gap-4">
        <div>
          <h3 class="font-semibold text-white">Generar Signed URL</h3>
          <p class="mt-0.5 text-xs text-gray-500">Acceso temporal vía CloudFront</p>
        </div>
        <button id="modal-close" class="rounded-lg p-1 text-gray-600 hover:text-gray-300 transition-colors">
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <!-- File key -->
      <div class="mb-4 rounded-lg border border-gray-700 bg-gray-800/60 px-3 py-2">
        <p class="text-xs text-gray-500 mb-0.5">Archivo</p>
        <p id="modal-filename" class="truncate text-sm font-mono text-gray-200"></p>
      </div>

      <!-- Expiry selector -->
      <label class="block mb-1 text-xs font-medium text-gray-400">Tiempo de expiración</label>
      <select
        id="expires-select"
        class="mb-4 w-full rounded-lg border border-gray-700 bg-gray-800 px-3 py-2.5 text-sm text-gray-200 focus:outline-none focus:ring-1 focus:ring-blue-500"
      >
        <option value="900">15 minutos</option>
        <option value="3600">1 hora</option>
        <option value="86400" selected>24 horas</option>
        <option value="604800">7 días</option>
      </select>

      <button
        id="generate-btn"
        class="w-full rounded-lg bg-blue-600 px-4 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-blue-500 flex items-center justify-center gap-2"
      >
        <svg id="generate-icon" class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
        </svg>
        <svg id="generate-spinner" class="hidden h-4 w-4 animate-spin" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"></path>
        </svg>
        Generar URL
      </button>

      <!-- URL result -->
      <div id="url-result" class="hidden mt-4 space-y-2">
        <label class="block text-xs font-medium text-gray-400">Signed URL generada</label>
        <div class="flex gap-2">
          <input
            id="signed-url-input"
            type="text"
            readonly
            class="min-w-0 flex-1 rounded-lg border border-gray-700 bg-gray-800 px-3 py-2 text-xs font-mono text-gray-300 focus:outline-none"
          />
          <button
            id="copy-btn"
            class="shrink-0 rounded-lg border border-gray-700 bg-gray-800 px-3 py-2 text-xs text-gray-300 hover:bg-gray-700 transition-colors flex items-center gap-1.5"
          >
            <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
            </svg>
            Copiar
          </button>
        </div>
        <p id="expires-label" class="text-xs text-gray-600 flex items-center gap-1">
          <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span></span>
        </p>
      </div>

    </div>
  </div>
</Layout>

<script is:inline define:vars={{ API_URL }}>
  // ── State ────────────────────────────────────────────────────────────────
  let selectedFile = null;
  let activeKey = null;

  // ── DOM refs ─────────────────────────────────────────────────────────────
  const dropZone      = document.getElementById('drop-zone');
  const fileInput     = document.getElementById('file-input');
  const filePreview   = document.getElementById('file-preview');
  const fileName      = document.getElementById('file-name');
  const fileSize      = document.getElementById('file-size');
  const clearBtn      = document.getElementById('clear-btn');
  const uploadBtn     = document.getElementById('upload-btn');
  const uploadIcon    = document.getElementById('upload-icon');
  const uploadSpinner = document.getElementById('upload-spinner');
  const uploadLabel   = document.getElementById('upload-label');
  const refreshBtn    = document.getElementById('refresh-btn');
  const refreshIcon   = document.getElementById('refresh-icon');
  const toast         = document.getElementById('toast');
  const stateLoading  = document.getElementById('state-loading');
  const stateEmpty    = document.getElementById('state-empty');
  const stateTable    = document.getElementById('state-table');
  const filesTbody    = document.getElementById('files-tbody');
  const modal         = document.getElementById('modal');
  const modalClose    = document.getElementById('modal-close');
  const modalFilename = document.getElementById('modal-filename');
  const expiresSelect = document.getElementById('expires-select');
  const generateBtn   = document.getElementById('generate-btn');
  const generateIcon  = document.getElementById('generate-icon');
  const generateSpinner = document.getElementById('generate-spinner');
  const urlResult     = document.getElementById('url-result');
  const signedUrlInput = document.getElementById('signed-url-input');
  const copyBtn       = document.getElementById('copy-btn');
  const expiresLabel  = document.getElementById('expires-label').querySelector('span');

  // ── Helpers ──────────────────────────────────────────────────────────────
  function formatBytes(bytes) {
    if (bytes === 0) return '0 B';
    const k = 1024;
    const sizes = ['B', 'KB', 'MB', 'GB'];
    const i = Math.floor(Math.log(bytes) / Math.log(k));
    return `${parseFloat((bytes / Math.pow(k, i)).toFixed(1))} ${sizes[i]}`;
  }

  function formatDate(dateStr) {
    return new Date(dateStr).toLocaleDateString('es-MX', {
      day: '2-digit',
      month: 'short',
      year: 'numeric',
    });
  }

  function expiresText(seconds) {
    if (seconds < 3600) return `${seconds / 60} minutos`;
    if (seconds < 86400) return `${seconds / 3600} hora${seconds / 3600 > 1 ? 's' : ''}`;
    return `${seconds / 86400} día${seconds / 86400 > 1 ? 's' : ''}`;
  }

  // ── Toast ─────────────────────────────────────────────────────────────────
  let toastTimer = null;
  function showToast(message, type = 'success') {
    clearTimeout(toastTimer);
    const styles = {
      success: 'border-green-500/30 bg-green-500/10 text-green-400',
      error:   'border-red-500/30   bg-red-500/10   text-red-400',
      info:    'border-blue-500/30  bg-blue-500/10  text-blue-400',
    };
    toast.className = `flex items-center gap-2.5 rounded-lg border px-4 py-3 text-sm font-medium ${styles[type]}`;
    toast.textContent = message;
    toast.classList.remove('hidden');
    toastTimer = setTimeout(() => toast.classList.add('hidden'), 4000);
  }

  // ── File selection ────────────────────────────────────────────────────────
  function handleFileSelect(file) {
    if (!file) return;
    if (file.size > 10 * 1024 * 1024) {
      showToast('El archivo supera el límite de 10 MB.', 'error');
      return;
    }
    selectedFile = file;
    fileName.textContent = file.name;
    fileSize.textContent = formatBytes(file.size);
    filePreview.classList.remove('hidden');
    uploadBtn.disabled = false;
  }

  function clearFile() {
    selectedFile = null;
    fileInput.value = '';
    filePreview.classList.add('hidden');
    uploadBtn.disabled = true;
  }

  // ── Drop zone ─────────────────────────────────────────────────────────────
  dropZone.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropZone.classList.add('border-blue-500/60', 'bg-blue-500/5');
  });

  dropZone.addEventListener('dragleave', () => {
    dropZone.classList.remove('border-blue-500/60', 'bg-blue-500/5');
  });

  dropZone.addEventListener('drop', (e) => {
    e.preventDefault();
    dropZone.classList.remove('border-blue-500/60', 'bg-blue-500/5');
    const file = e.dataTransfer?.files?.[0];
    if (file) handleFileSelect(file);
  });

  fileInput.addEventListener('change', () => {
    handleFileSelect(fileInput.files?.[0]);
  });

  clearBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    clearFile();
  });

  // ── Upload ────────────────────────────────────────────────────────────────
  uploadBtn.addEventListener('click', async () => {
    if (!selectedFile) return;

    uploadBtn.disabled = true;
    uploadIcon.classList.add('hidden');
    uploadSpinner.classList.remove('hidden');
    uploadLabel.textContent = 'Subiendo...';

    try {
      const formData = new FormData();
      formData.append('file', selectedFile);

      const res = await fetch(`${API_URL}/files/upload`, {
        method: 'POST',
        body: formData,
      });

      const json = await res.json();

      if (!res.ok) throw new Error(json.error?.message ?? 'Error al subir');

      showToast(`Archivo subido: ${json.data.key}`, 'success');
      clearFile();
      await loadFiles();
    } catch (err) {
      showToast(err.message, 'error');
    } finally {
      uploadBtn.disabled = false;
      uploadIcon.classList.remove('hidden');
      uploadSpinner.classList.add('hidden');
      uploadLabel.textContent = 'Subir a S3';
    }
  });

  // ── Files list ────────────────────────────────────────────────────────────
  function showState(state) {
    stateLoading.classList.toggle('hidden', state !== 'loading');
    stateEmpty.classList.toggle('hidden',   state !== 'empty');
    stateTable.classList.toggle('hidden',   state !== 'table');
  }

  function renderFiles(files) {
    if (!files.length) { showState('empty'); return; }

    filesTbody.innerHTML = files.map((f) => `
      <tr class="group hover:bg-gray-800/30 transition-colors">
        <td class="px-2 py-3.5">
          <span class="font-mono text-xs text-gray-300 truncate block max-w-[220px]" title="${f.key}">${f.key}</span>
        </td>
        <td class="px-2 py-3.5 text-xs text-gray-400 whitespace-nowrap">${formatBytes(f.size)}</td>
        <td class="px-2 py-3.5 text-xs text-gray-400 whitespace-nowrap">${formatDate(f.lastModified)}</td>
        <td class="px-2 py-3.5 text-right">
          <div class="inline-flex items-center gap-1.5">
            <button
              onclick="openModal('${f.key}')"
              class="inline-flex items-center gap-1 rounded-md px-2.5 py-1.5 text-xs font-medium text-blue-400 hover:bg-blue-500/10 transition-colors"
            >
              <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
              </svg>
              URL
            </button>
            <button
              onclick="deleteFile('${f.key}')"
              class="inline-flex items-center gap-1 rounded-md px-2.5 py-1.5 text-xs font-medium text-gray-500 hover:text-red-400 hover:bg-red-500/10 transition-colors"
            >
              <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
              </svg>
              Eliminar
            </button>
          </div>
        </td>
      </tr>
    `).join('');

    showState('table');
  }

  async function loadFiles() {
    showState('loading');
    refreshIcon.classList.add('animate-spin');
    try {
      const res = await fetch(`${API_URL}/files`);
      const json = await res.json();
      if (!res.ok) throw new Error(json.error?.message ?? 'Error al listar');
      renderFiles(json.data);
    } catch (err) {
      showToast(err.message, 'error');
      showState('empty');
    } finally {
      refreshIcon.classList.remove('animate-spin');
    }
  }

  refreshBtn.addEventListener('click', loadFiles);

  // ── Delete ────────────────────────────────────────────────────────────────
  window.deleteFile = async (key) => {
    if (!confirm(`¿Eliminar "${key}" del bucket?\nEsta acción no se puede deshacer.`)) return;

    try {
      const res = await fetch(`${API_URL}/files/${encodeURIComponent(key)}`, { method: 'DELETE' });
      const json = await res.json();
      if (!res.ok) throw new Error(json.error?.message ?? 'Error al eliminar');
      showToast('Archivo eliminado correctamente.', 'success');
      await loadFiles();
    } catch (err) {
      showToast(err.message, 'error');
    }
  };

  // ── Modal ─────────────────────────────────────────────────────────────────
  window.openModal = (key) => {
    activeKey = key;
    modalFilename.textContent = key;
    urlResult.classList.add('hidden');
    signedUrlInput.value = '';
    modal.classList.remove('hidden');
  };

  modalClose.addEventListener('click', () => modal.classList.add('hidden'));
  modal.addEventListener('click', (e) => { if (e.target === modal) modal.classList.add('hidden'); });

  // close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') modal.classList.add('hidden');
  });

  // ── Generate Signed URL ───────────────────────────────────────────────────
  generateBtn.addEventListener('click', async () => {
    if (!activeKey) return;

    generateBtn.disabled = true;
    generateIcon.classList.add('hidden');
    generateSpinner.classList.remove('hidden');

    try {
      const expires = expiresSelect.value;
      const res = await fetch(
        `${API_URL}/files/${encodeURIComponent(activeKey)}/signed-url?expires=${expires}`
      );
      const json = await res.json();
      if (!res.ok) throw new Error(json.error?.message ?? 'Error al generar URL');

      signedUrlInput.value = json.data.signedUrl;
      expiresLabel.textContent = `Expira en ${expiresText(Number(expires))}`;
      urlResult.classList.remove('hidden');
    } catch (err) {
      showToast(err.message, 'error');
    } finally {
      generateBtn.disabled = false;
      generateIcon.classList.remove('hidden');
      generateSpinner.classList.add('hidden');
    }
  });

  // ── Copy URL ──────────────────────────────────────────────────────────────
  copyBtn.addEventListener('click', async () => {
    const url = signedUrlInput.value;
    if (!url) return;
    try {
      await navigator.clipboard.writeText(url);
      copyBtn.textContent = '¡Copiado!';
      setTimeout(() => (copyBtn.innerHTML = `
        <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
        </svg>
        Copiar
      `), 2000);
    } catch {
      showToast('No se pudo copiar al portapapeles.', 'error');
    }
  });

  // ── Init ──────────────────────────────────────────────────────────────────
  loadFiles();
</script>
